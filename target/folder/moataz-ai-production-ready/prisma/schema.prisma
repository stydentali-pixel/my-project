generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProviderStatus {
  ENABLED
  DISABLED
}

model User {
  id             String        @id @default(cuid())
  email          String?       @unique
  name           String?
  role           UserRole      @default(USER)
  telegramUser   TelegramUser?
  sessions       ChatSession[]
  requests       AiRequestLog[]
  generatedFiles GeneratedFile[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model TelegramUser {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  isAdmin      Boolean  @default(false)
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Agent {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  systemPrompt String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Provider {
  id        String         @id @default(cuid())
  slug      String         @unique
  name      String
  model     String?
  status    ProviderStatus @default(ENABLED)
  priority  Int            @default(100)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String?
  source    String        @default("web")
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  provider  String?
  model     String?
  agent     String?
  createdAt DateTime    @default(now())
}

model AiRequestLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider   String
  model      String?
  agent      String?
  promptSize Int      @default(0)
  success    Boolean  @default(false)
  error      String?
  latencyMs  Int      @default(0)
  createdAt  DateTime @default(now())
}

model GeneratedFile {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  filename  String
  sizeBytes Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
}

model DataFlowPipeline {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DataFlowRun {
  id        String   @id @default(cuid())
  mode      String
  inputSize Int      @default(0)
  outputSize Int     @default(0)
  provider  String?
  model     String?
  success   Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())
}
