# =========================
# App
# =========================
NODE_ENV=production
PORT=3000
APP_NAME=Moataz AI
PUBLIC_URL=https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
ADMIN_PANEL_KEY=change-this-long-secret

# =========================
# Database - PostgreSQL / Supabase / Railway Postgres
# =========================
DATABASE_URL=
DIRECT_URL=

# =========================
# AI Providers
# =========================
DEFAULT_AI_PROVIDER=auto
AI_REQUEST_TIMEOUT_MS=45000

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

HF_TOKEN=
HF_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

POLLINATIONS_TEXT_MODEL=openai
POLLINATIONS_IMAGE_MODEL=flux
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024

# =========================
# Telegram Bot
# =========================
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-this-telegram-secret
TELEGRAM_OWNER_ID=
TELEGRAM_ADMIN_IDS=

# =========================
# Files
# =========================
PDF_ENABLED=true
ZIP_ENABLED=true
FILES_MAX_SIZE_MB=20

# =========================
# DataFlow Integration
# =========================
DATAFLOW_ENABLED=true
DATAFLOW_WORKER_URL=
DATAFLOW_MAX_INPUT_CHARS=12000
DATAFLOW_DEFAULT_CHUNK_SIZE=900
DATAFLOW_DEFAULT_OVERLAP=120
